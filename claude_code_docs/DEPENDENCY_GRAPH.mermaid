graph TD
    subgraph config["config/"]
        settings["settings.py<br/>Settings, PathsConfig, FetcherConfigs"]
        constants["constants.py<br/>Constants, field maps, séries BCB"]
    end

    subgraph utils["utils/"]
        logger["logger.py<br/>get_logger(), setup_logging()"]
        decorators["decorators.py<br/>@retry, @cache, @rate_limit, @log"]
        helpers["helpers.py<br/>validate_ticker()"]
    end

    subgraph core["core/"]
        engine["engine.py<br/>DAGEngine, Node, PipelineContext"]
        result["result.py<br/>Ok, Err, Result"]
        models["models/<br/>Asset, Portfolio, *Metrics"]
        registry["registry.py<br/>PIPELINE_PRESETS, create_engine()"]
        subgraph core_nodes["nodes/"]
            nodes["Load, Fetch, Export, Alert, Storage"]
            ingest_nodes["IngestPricesNode, IngestMacroNode,<br/>IngestFundamentalsNode"]
        end
    end

    subgraph data["data/"]
        subgraph fetchers["fetchers/"]
            yahoo["yahoo_fetcher.py<br/>YahooFinanceFetcher"]
            bcb["bcb_fetcher.py<br/>BCBFetcher"]
            ibge["ibge_fetcher.py<br/>IBGEFetcher"]
            fred["fred_fetcher.py<br/>FREDFetcher"]
            cvm["cvm_fetcher.py<br/>CVMFetcher"]
            tesouro["tesouro_fetcher.py<br/>TesouroDiretoFetcher"]
            ddm["ddm_fetcher.py<br/>DDMFetcher"]
        end
        lake["lake/<br/>DataLake, PriceLake, MacroLake,<br/>FundamentalsLake, NewsLake"]
        loaders["loaders/<br/>ExcelLoader, PortfolioLoader"]
        exporters["exporters/<br/>ExcelExporter, PriceExporter"]
        storage["storage/<br/>SnapshotStore"]
    end

    subgraph analyzers["analyzers/"]
        portfolio_a["portfolio_analyzer.py<br/>→ ctx[portfolio_metrics]"]
        risk_a["risk_analyzer.py<br/>→ ctx[risk_metrics]"]
        macro_a["macro_analyzer.py<br/>→ ctx[macro_context]"]
        market_a["market_analyzer.py<br/>→ ctx[market_metrics]"]
        rebalancer["rebalancer.py<br/>→ ctx[rebalance_recommendations]"]
        currency_a["currency_analyzer.py<br/>→ ctx[currency_metrics]"]
        commodity_a["commodity_analyzer.py<br/>→ ctx[commodity_metrics]"]
        fiscal_a["fiscal_analyzer.py<br/>→ ctx[fiscal_metrics]"]
    end

    subgraph alerts["alerts/"]
        alert_engine["engine.py<br/>AlertEngine, AlertRule"]
        channels["channels.py<br/>Console, Log channels"]
    end

    %% Config → tudo
    settings --> logger
    settings --> yahoo
    settings --> bcb
    settings --> ibge
    settings --> fred
    settings --> cvm
    settings --> tesouro
    settings --> loaders
    constants --> yahoo
    constants --> bcb
    constants --> loaders

    %% Utils → componentes
    decorators --> yahoo
    decorators --> bcb
    decorators --> ibge
    decorators --> fred
    decorators --> cvm
    decorators --> tesouro
    decorators --> portfolio_a
    decorators --> risk_a
    decorators --> macro_a
    logger --> engine

    %% Core internals
    result --> models
    engine --> nodes
    engine --> registry
    models --> nodes
    models --> analyzers

    %% Fetchers → IngestNodes
    yahoo --> ingest_nodes
    bcb --> ingest_nodes
    ibge --> ingest_nodes
    fred --> ingest_nodes
    cvm --> ingest_nodes
    tesouro --> ingest_nodes

    %% Lake → IngestNodes
    lake --> ingest_nodes

    %% Data → core
    yahoo --> nodes
    bcb --> macro_a
    bcb --> market_a
    ibge --> macro_a
    loaders --> nodes
    exporters --> nodes
    storage --> nodes

    %% IngestNodes → Registry
    ingest_nodes --> registry

    %% Fetchers → novos analyzers
    bcb --> currency_a
    bcb --> fiscal_a
    fred --> currency_a
    yahoo --> currency_a
    yahoo --> commodity_a

    %% Registry agrupa tudo
    nodes --> registry
    portfolio_a --> registry
    risk_a --> registry
    macro_a --> registry
    market_a --> registry
    rebalancer --> registry
    currency_a --> registry
    commodity_a --> registry
    fiscal_a --> registry
    alert_engine --> registry
