# Configurações de ambiente
ENVIRONMENT=development
DEBUG=True

# Logging
LOG_LEVEL=INFO

# API Keys (obtenha suas próprias chaves)
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
BRAPI_API_KEY=your_brapi_key_here
CEI_USERNAME=your_cei_username
CEI_PASSWORD=your_cei_password

# Configurações de conexão
DATABASE_URL=sqlite:///data/portfolio.db
REDIS_URL=redis://localhost:6379

# Configurações de mercado
DEFAULT_CURRENCY=BRL
MARKET_TIMEZONE=America/Sao_Paulo

# Notificações
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# Limites e thresholds
MAX_PORTFOLIO_SIZE=50
REBALANCE_THRESHOLD=0.05
CACHE_TTL_MINUTES=5